{
  "name": "mentorib",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.20.0",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:arch": "eslint . && tsx scripts/audit-architectural-rules.ts",
    "lint:arch:test": "tsx scripts/test-architectural-rules.ts",
    "typecheck": "tsc --noEmit",
    "prepare": "simple-git-hooks || true"
  },
  "dependencies": {
    "@supabase/ssr": "0.10.2",
    "@supabase/supabase-js": "2.104.0",
    "country-flag-icons": "^1.6.16",
    "drizzle-orm": "0.45.2",
    "lucide-react": "^1.11.0",
    "next": "16.2.4",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "stripe": "22.0.2"
  },
  "devDependencies": {
    "@types/node": "24.12.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.4",
    "lint-staged": "16.4.0",
    "simple-git-hooks": "2.13.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged && pnpm tsx scripts/audit-architectural-rules.ts"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs}": "eslint --max-warnings=0 --no-warn-ignored"
  }
}
